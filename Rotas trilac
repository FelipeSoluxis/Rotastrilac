const checked = JSON.parse(localStorage.getItem('trilac_checked')||'{}');
const notes   = JSON.parse(localStorage.getItem('trilac_notes')||'{}');

let currentDay = 1;

function saveChecked(){ localStorage.setItem('trilac_checked', JSON.stringify(checked)); }
function saveNotes(){ localStorage.setItem('trilac_notes', JSON.stringify(notes)); }

function getKey(day,order){ return day+'-'+order; }

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('screen-'+id).classList.add('active');
  const map={hoje:'📅 Hoje',semana:'📆 Semana',roteiro:'📋 Roteiro',objecoes:'💬 Objeções'};
  document.querySelectorAll('.nav-btn').forEach(b=>{
    if(b.textContent.includes(map[id])) b.classList.add('active');
  });
  if(id==='hoje') renderVisits();
  if(id==='semana') renderWeek();
}

function buildDaySelector(){
  const sel = document.getElementById('day-selector');
  sel.innerHTML='';
  const today = new Date();
  for(let d=1;d<=176;d++){
    const p=document.createElement('button');
    p.className='day-pill'+(d===currentDay?' active':'');
    p.textContent='Dia '+d;
    p.onclick=()=>{ currentDay=d; buildDaySelector(); renderVisits(); };
    sel.appendChild(p);
  }
  // scroll current into view
  const pills = sel.querySelectorAll('.day-pill');
  if(pills[currentDay-1]) pills[currentDay-1].scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});
}

function renderVisits(){
  const entry = ROTA[currentDay-1];
  const total = entry.visits.length;
  const done = entry.visits.filter(v=>checked[getKey(currentDay,v.order)]).length;
  const pct = Math.round(done/total*100);

  document.getElementById('status-bar').innerHTML=`
    <div class="stat-card"><div class="stat-num" style="color:var(--blue)">${total}</div><div class="stat-lbl">Visitas</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--green)">${done}</div><div class="stat-lbl">Concluídas</div></div>
    <div class="stat-card"><div class="stat-num">${total-done}</div><div class="stat-lbl">Pendentes</div></div>
    <div class="stat-card">
      <div class="stat-num" style="color:var(--blue)">${pct}%</div>
      <div class="stat-lbl">Progresso</div>
      <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
    </div>`;

  const dayNames=['','Segunda','Terça','Quarta','Quinta','Sexta'];
  const wday = ((currentDay-1)%5)+1;
  const weekNum = Math.ceil(currentDay/5);
  document.getElementById('visits-title').textContent = `Semana ${weekNum} • ${dayNames[wday]}`;

  document.getElementById('visits-container').innerHTML = entry.visits.map(v=>{
    const key = getKey(currentDay,v.order);
    const isDone = checked[key];
    const seg = SEG[v.seg];
    const n = notes[key]||'';
    return `<div class="visit-card${isDone?' checked':''}" id="card-${key}">
      <div class="visit-header" onclick="toggleVisit('${key}')">
        <div class="order-badge badge-${v.seg}" style="background:${isDone?'#E8F5E9':''}; color:${isDone?'#2E7D32':''}">
          ${isDone?'✓':v.order}
        </div>
        <div class="visit-info">
          <div class="visit-time">${v.time}</div>
          <div class="visit-name">${v.name}</div>
        </div>
        <span class="seg-badge seg-${v.seg}">${seg.label}</span>
        <span class="chevron-icon" id="chev-${key}">›</span>
      </div>
      <div class="visit-body" id="body-${key}">
        <div class="detail-row">
          <span class="detail-icon">🏷️</span>
          <div><div class="detail-label">Segmento</div><div class="detail-value">${seg.label}</div></div>
        </div>
        <div class="detail-row">
          <span class="detail-icon">🕐</span>
          <div><div class="detail-label">Horário sugerido</div><div class="detail-value">${v.time} (±30 min)</div></div>
        </div>
        <textarea class="notes-area" rows="2" placeholder="Anotações da visita..." 
          onchange="saveNote('${key}', this.value)">${n}</textarea>
        <div class="action-row">
          <button class="btn-action btn-maps" onclick="openMaps('${v.name}')">🗺️ Maps</button>
          <button class="btn-action btn-wpp" onclick="openWpp('${v.name}')">💬 WhatsApp</button>
          <button class="btn-action btn-check" onclick="toggleCheck('${key}')">${isDone?'↩ Desfazer':'✓ Concluir'}</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function toggleVisit(key){
  const body = document.getElementById('body-'+key);
  const chev = document.getElementById('chev-'+key);
  const open = body.classList.contains('open');
  document.querySelectorAll('.visit-body').forEach(b=>b.classList.remove('open'));
  document.querySelectorAll('.chevron-icon').forEach(c=>{ c.classList.remove('open'); c.textContent='›'; });
  if(!open){ body.classList.add('open'); chev.classList.add('open'); chev.textContent='⌄'; }
}

function toggleCheck(key){
  checked[key] = !checked[key];
  saveChecked();
  renderVisits();
}

function saveNote(key, val){
  notes[key] = val;
  saveNotes();
}

function openMaps(name){
  const q = encodeURIComponent(name + ' São Paulo SP');
  window.open('https://maps.google.com/?q='+q,'_blank');
}

function openWpp(name){
  const msg = encodeURIComponent('Olá! Sou representante da Trilac / Sô Minas. Acabei de visitar vocês e gostaria de confirmar nosso pedido. Fico à disposição!');
  window.open('https://wa.me/?text='+msg,'_blank');
}

function renderWeek(){
  const sel = document.getElementById('week-select');
  if(!sel.options.length){
    for(let w=1;w<=36;w++){
      const start=(w-1)*5+1, end=Math.min(start+4,176);
      sel.add(new Option(`Semana ${w}  (Dias ${start}–${end})`,w));
    }
  }
  const week = parseInt(sel.value)||1;
  const start=(week-1)*5+1, end=Math.min(start+4,176);
  const dayNames=['','Segunda','Terça','Quarta','Quinta','Sexta'];
  let html='';
  for(let d=start;d<=end;d++){
    const entry=ROTA[d-1];
    const done=entry.visits.filter(v=>checked[getKey(d,v.order)]).length;
    const wday=((d-1)%5)+1;
    html+=`<div class="week-day">
      <div class="week-day-header" onclick="toggleWeekDay(this)">
        <div class="week-day-num${d===currentDay?' today':''}">${d}</div>
        <div class="week-day-info">
          <div class="week-day-title">${dayNames[wday]}</div>
          <div class="week-day-sub">${done}/4 concluídas</div>
        </div>
        <div class="progress-bar" style="width:60px"><div class="progress-fill" style="width:${done*25}%"></div></div>
      </div>
      <div class="week-day-body">
        ${entry.visits.map(v=>{
          const s=SEG[v.seg];
          const done2=checked[getKey(d,v.order)];
          return `<div class="mini-visit">
            <span class="mini-time">${v.time}</span>
            <span class="mini-name" style="${done2?'text-decoration:line-through;color:#90A4AE':''}">${v.name}</span>
            <span class="mini-seg seg-${v.seg}">${s.label}</span>
          </div>`;
        }).join('')}
        <button style="margin-top:8px;padding:8px 14px;background:var(--blue);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;width:100%"
          onclick="currentDay=${d}; showScreen('hoje')">Ver detalhes do Dia ${d} →</button>
      </div>
    </div>`;
  }
  document.getElementById('week-container').innerHTML=html;
}

function toggleWeekDay(el){
  const body=el.nextElementSibling;
  const open=body.style.display==='block';
  document.querySelectorAll('.week-day-body').forEach(b=>b.style.display='none');
  if(!open) body.style.display='block';
}

